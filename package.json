{
  "name": "fluidflow",
  "private": true,
  "version": "0.9.0",
  "type": "module",
  "engines": {
    "node": ">=20.12.0"
  },
  "scripts": {
    "dev": "concurrently -n \"FE,BE\" -c \"cyan,yellow\" \"npm run dev:frontend\" \"npm run dev:server\"",
    "dev:frontend": "vite",
    "dev:server": "nodemon",
    "build": "vite build",
    "preview": "vite preview",
    "server": "tsx server/index.ts",
    "server:watch": "tsx server/watchdog.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:security": "vitest run --run tests/security",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@google/genai": "^1.52.0",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/compression": "^1.8.1",
    "@types/dompurify": "^3.2.0",
    "@webcontainer/api": "^1.6.4",
    "@xyflow/react": "^12.10.2",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "diff": "^9.0.0",
    "dompurify": "^3.4.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "file-saver": "^2.0.5",
    "helmet": "^8.1.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.577.0",
    "monaco-editor": "^0.55.1",
    "openai": "^6.38.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "simple-git": "^3.36.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "node-forge": "^1.4.0",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^7.3.3",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "dompurify": "^3.4.5"
  }
}
